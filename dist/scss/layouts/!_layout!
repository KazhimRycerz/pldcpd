  @keyframes hide_home_aside {
    0%  {transform: translateX(0%) /* perspective(300px) rotateY(0deg) */;}
    30% {transform: translateX(60%) scale(90%) /* rotateY(60deg)perspective(300px); */ }
    60% {z-index:1;}
    /* 50% {transform: translateX(0%);z-index:1;}
    75% {transform: translateX(-60%);} */
    99% {transform: translateX(-120%) scale(90%)/* rotateY(0deg) perspective(0rem) */; z-index: -1; opacity: 1;}
    100% {transform: translateX(-120%) scale(90%)/* rotateY(0deg) perspective(0rem) */; z-index: -1; opacity: 0;}
    }

  @keyframes show_home_aside {
    0%  {opacity:0;}
    1%  {transform: translateX(-120%) scale(90%) /* rotateY(0deg) perspective(0rem) */; z-index: -1;opacity: 1;}
    30% {z-index:1;}
    60% {transform: translateX(60%) scale(90%) /* rotateY(180deg) perspective(10rem) */; }
    100% {transform: translateX(0%) scale(100%);z-index:11;}
    }

    @keyframes moveButton {
      0%  {transform: translateX(0%) rotate(0%);z-index:11;}
      50% {z-index: 0;}
      100% {transform: translateX(0%) translateY(30px) rotate(-90deg);z-index:0; display: block; right:calc(10vw - 35px)}
      }

    @keyframes moveButtonback {
      0%  {transform: translateX(0%) translateY(30px) rotate(-90deg);z-index:0;right:calc(10vw - 35px)}
      90%  {z-index: 0;}
      100% {transform: translateX(0%) rotate(0%);z-index: 11;}
    }
    

