          border-radius: 0 0 10px 10px;
          position: relative;
          bottom: 0px;
          box-shadow: 2px 2px 10px 3px $first-color, 2px 2px 10px 3px $first-color inset;
          padding: 0 5px 5px 5px;
        }
      }
    }
