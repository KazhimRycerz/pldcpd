  main:hover .rotate, main:focus .rotate, header:hover .rotate, header:focus .rotate, footer:hover .rotate, footer:focus .rotate {
    animation: none;
  }
  
  
  /*Alles zum Header*/
  header {
    font-family: $primary-font;
    position: fixed;
    top: 0px;
    left: 0px;
    margin-bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: nowrap;
    width: 100vw;
    height: 100px;
    background-color: $first-color;
    box-shadow: $boxshadow;
    z-index: 99;
   }
  
  /* Neue Navigation*/
  
  .navheader {
    width:30%;
    position:relative;
    left: 10.5%;
    #dropdown {
      position: relative;
      left:0;
      width: 100%;
      display: block;
      #dropbtn {
        font-family: $primary-font;
        width: 140px;
        text-align: left;
        position: relative;
        background-color: transparent;
        color: black;
        font-size: $small;
        border: none;
      }
      ul {
        color: black;
        font-size: $small;
        display: flex;
        opacity: 0;
        flex-direction: row;
        justify-content: left;
        position: absolute;
        bottom: -11px;
        left: -20px;
        height: auto;
        width: auto;
        background-color: none;
        z-index: 98;
        text-decoration: none;
        
        li {        
          padding: 0 20px;
          display: flex;
          font-size: $small;
          background-color: none;
          /* box-shadow: $boxshadow; */
          * {
            text-decoration: none;
          }
          a {
            color: black;
          }
        }
      }
    }
  }
  
  @keyframes navpresenter {
  0%  {opacity: 0;}
  100% {opacity: 1;}
  }
  
  #dropdown:hover #dropdown-content {
    opacity: 1;
    width: auto;
    li:nth-child(2){
      opacity: 0;
      animation: navpresenter 1s forwards; 
      animation-fill-mode: both;
    }
    li:nth-child(3){
      opacity: 0;
      animation: navpresenter 2s  forwards;
    }
    li:nth-child(4){
      opacity: 0;
      animation: navpresenter 3s  forwards;
    }
    li a:hover {
      color: $cpdred;
      text-shadow: 1px 1px 20px $cpdred;
    }
  }
  
  #dropbtn p::after {
    content: "";
    width: 10px;
    height: 10px;
    
  }
  
  #dropdown:hover #dropbtn {
    display: none;
    opacity: 0;
  }
  
  .image_header {
      height:30px;
   }
  
  .text_header {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: nowrap;
    margin-top: 0px;
    margin-left: -15%;
    font-size: $small;
    text-decoration: none;
    vertical-align: top;
    line-height: 1.2;
  }
  
  #header_myaccount {
    background-color: $first-color;
    width: 15vw;
    height: 60px;
    margin-right: 30px;
    font-size: $small;
      ul {
        display: flex;
        flex-flow: column nowrap;
        justify-content: center;
        align-items: end;
        gap: 0px;
        li {
          list-style-type: none;
          a {
            text-decoration:none;
            color: black;
          }
          a:hover{
            text-decoration:none;
            color: $cpdred;
            text-shadow: 1px 1px 20px $cpdred;
          }
        }
      }
      
      
      /* :hover {
        box-shadow: $boxshadow;
      } */
      button {
        display: none;
      }
  }
  
